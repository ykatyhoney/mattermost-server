              <figure
                class="image-loaded-container"
              >
                <img
                  aria-label="file thumbnail name"
                  class="image-permalink"
                  src="/api/v4/files/file_info_id/preview"
                  tabindex="0"
                />
                <span
                  class="image-preview-utility-buttons-container"
                >
                  <a
                    aria-label="Download"
                    class="style--none size-aware-image__download"
                    download=""
                    href="/api/v4/files/file_info_id"
                    rel="noopener noreferrer"
