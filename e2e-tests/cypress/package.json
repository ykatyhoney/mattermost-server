  "scripts": {
    "check-types": "tsc -b",
    "cypress:open": "cross-env TZ=Etc/UTC cypress open",
    "cypress:run": "cross-env TZ=Etc/UTC cypress run",
    "cypress:run:chrome": "cross-env TZ=Etc/UTC cypress run --browser chrome",
